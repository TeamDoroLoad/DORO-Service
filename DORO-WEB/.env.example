# Spring Boot 백엔드 준비되면 실제 주소로 교체
VITE_API_BASE_URL=http://localhost:8080/api/v1
# true면 mockData.ts로 응답, false면 VITE_API_BASE_URL로 실제 fetch
VITE_USE_MOCK=true

# TMAP Open API 포털(https://tmapapi.sktelecom.com)에서 발급받은 JavaScript(Web) appKey.
# 도메인 제한형 키라 브라우저에 노출돼도 되는 값이지만, 그래도 저장소에는 커밋하지 않는다(.env는 .gitignore 처리됨).
VITE_TMAP_APP_KEY=
